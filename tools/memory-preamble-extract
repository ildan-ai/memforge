#!/usr/bin/env python3
# memory-preamble-extract — extract the operator-curated preamble from
# an existing MEMORY.md into a _memforge.yaml config file (Phase 1
# migration helper companion).
#
# ADR: 0001 §Phase 1 T3 (closes the second BLOCKER from memory-index-gen
# tabletop: preamble loss when generator is run on a folder without
# _memforge.yaml)
#
# Algorithm:
#   - Read MEMORY.md.
#   - Title = first H1 line (`# <title>`); fallback "Memory Index".
#   - Preamble = everything between the H1 and the first bullet line
#     (`- [`) or the first H2 (`## `), whichever comes first.
#   - Write _memforge.yaml with title + preamble fields.
#   - Skip if _memforge.yaml already exists (operator-set).
#
# Modes:
#   --dry-run   Show what would be written; don't write.
#   --apply     Write _memforge.yaml.
#
# Defaults: per-cwd memory + ~/.claude/global-memory/.

from __future__ import annotations

import argparse
import os
import re
import sys
from pathlib import Path
from typing import Optional


H1_RE = re.compile(r"^#\s+(.+?)\s*$")
H2_RE = re.compile(r"^##\s+")
BULLET_RE = re.compile(r"^-\s+\[")
GENERATED_HEADER_RE = re.compile(r"^<!-- GENERATED BY memory-index-gen", re.IGNORECASE)


def extract(memory_md: Path) -> Optional[dict]:
    """Returns {title, preamble} or None if MEMORY.md missing."""
    if not memory_md.exists():
        return None
    try:
        text = memory_md.read_text(encoding="utf-8")
    except (OSError, UnicodeDecodeError):
        return None

    lines = text.splitlines()
    title = "Memory Index"
    preamble_lines: list[str] = []
    title_idx: Optional[int] = None
    for i, line in enumerate(lines):
        m = H1_RE.match(line)
        if m:
            title = m.group(1).strip()
            title_idx = i
            break
    start = (title_idx + 1) if title_idx is not None else 0
    for i in range(start, len(lines)):
        line = lines[i]
        if BULLET_RE.match(line):
            break
        if H2_RE.match(line):
            break
        if GENERATED_HEADER_RE.match(line):
            break
        preamble_lines.append(line)

    preamble = "\n".join(preamble_lines).strip()
    return {"title": title, "preamble": preamble}


def render_yaml(cfg: dict) -> str:
    """Hand-render a minimal YAML for the _memforge.yaml config. Avoids
    a PyYAML dependency for the writer side."""
    out: list[str] = []
    title = cfg.get("title", "Memory Index").replace('"', '\\"')
    out.append(f'title: "{title}"')
    preamble = cfg.get("preamble", "")
    if not preamble:
        out.append('preamble: ""')
    else:
        out.append("preamble: |")
        for line in preamble.splitlines():
            out.append(f"  {line}")
    return "\n".join(out) + "\n"


def cmd_run(folders: list[Path], apply: bool) -> int:
    rc = 0
    for folder in folders:
        if not folder.exists():
            sys.stderr.write(f"warning: skipping nonexistent {folder}\n")
            continue
        target_yaml = folder / "_memforge.yaml"
        memory_md = folder / "MEMORY.md"
        print(f"\n====== {folder} ======")
        if target_yaml.exists():
            print(f"  _memforge.yaml already exists; skipping")
            continue
        cfg = extract(memory_md)
        if cfg is None:
            print(f"  MEMORY.md missing; nothing to extract")
            continue
        rendered = render_yaml(cfg)
        print(f"  title: {cfg['title']}")
        if cfg["preamble"]:
            print(f"  preamble ({len(cfg['preamble'].splitlines())} lines):")
            for line in cfg["preamble"].splitlines()[:10]:
                print(f"    {line}")
            if len(cfg["preamble"].splitlines()) > 10:
                print(f"    ... +{len(cfg['preamble'].splitlines()) - 10} more lines")
        else:
            print("  (no preamble; only the H1 title)")
        if apply:
            target_yaml.write_text(rendered, encoding="utf-8")
            print(f"  WROTE {target_yaml}")
        else:
            print(f"  (dry-run; pass --apply to write {target_yaml})")
    return rc


def default_paths() -> list[Path]:
    out: list[Path] = []
    home = Path.home()
    user = os.environ.get("USER", "")
    if user:
        per_cwd = home / ".claude" / "projects" / f"{user}-claude-projects" / "memory"
        if per_cwd.exists():
            out.append(per_cwd)
    glob = home / ".claude" / "global-memory"
    if glob.exists():
        out.append(glob)
    return out


def main() -> int:
    p = argparse.ArgumentParser(
        prog="memory-preamble-extract",
        description="Extract MEMORY.md preamble into _memforge.yaml (Phase 1 migration helper).",
    )
    p.add_argument("--path", action="append", default=[], help="Folder (repeatable)")
    g = p.add_mutually_exclusive_group()
    g.add_argument("--dry-run", action="store_true")
    g.add_argument("--apply", action="store_true")
    args = p.parse_args()

    folders = [Path(x).resolve() for x in args.path] if args.path else default_paths()
    if not folders:
        sys.stderr.write("error: no folders specified and no defaults found\n")
        return 2

    if args.apply:
        print("=== APPLY MODE: _memforge.yaml will be written ===")
    else:
        print("=== DRY-RUN MODE: pass --apply to write ===")

    return cmd_run(folders, apply=args.apply)


if __name__ == "__main__":
    sys.exit(main())
